generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// BRANCH (الفرع)
// ─────────────────────────────────────────────
model Branch {
  id        String   @id @default(uuid())
  name      String   // "قطر" | "الإمارات" ...
  code      String   @unique // "QA" | "AE" | "SA" | "BH" | "SY" | "TR"
  currency  String   @default("QAR")
  country   String
  flag      String   // 🇶🇦 emoji
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  users          User[]
  projects       Project[]
  wallets        CompanyWallet[]
  categories     Category[]
  voucherCounters VoucherCounter[]
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id                  String               @id @default(uuid())
  name                String
  email               String?              @unique
  phone               String               @unique
  password            String
  role                String               @default("USER") // ROOT | ADMIN | GENERAL_MANAGER | GLOBAL_ACCOUNTANT | USER
  jobTitle            String?
  salary              Float?              // v4: hidden from UI but kept in DB
  image               String?
  savedSignature      String?              // v5: توقيع محفوظ (base64 PNG)
  branchId            String?              // v8: الفرع — اختياري (ROOT و GM بدون فرع)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isDeleted           Boolean              @default(false)
  deletedAt           DateTime?

  // Relations
  branch              Branch?              @relation(fields: [branchId], references: [id])
  deposits            Deposit[]
  invoicesCreated     Invoice[]            @relation("InvoiceCreator")
  receivedMessages    Message[]            @relation("MessageReceiver")
  sentMessages        Message[]            @relation("MessageSender")
  managedProjects     Project[]            @relation("ProjectManager")
  memberships         ProjectMember[]
  purchases           Purchase[]
  custodies           EmployeeCustody[]
  outOfPocketDebts    OutOfPocketDebt[]
  walletEntries       WalletEntry[]        @relation("WalletEntryCreator")
  settledDebts        OutOfPocketDebt[]    @relation("DebtSettler")
  financeRequests     FinanceRequest[]     @relation("FinanceRequester")
  approvedRequests    FinanceRequest[]     @relation("FinanceApprover")
  custodyReturnsMade  CustodyReturn[]      @relation("CustodyReturner")  // D2: audit trail
  custodyReturnsRecorded CustodyReturn[]   @relation("CustodyRecorder")  // D2: audit trail
  custodyConfirmations CustodyConfirmation[] @relation("CustodyConfirmer") // v6: audit trail

  @@index([branchId])
}
// ─────────────────────────────────────────────
// COMPANY WALLET (خزنة الشركة)
// ─────────────────────────────────────────────
model CompanyWallet {
  id        String        @id @default(uuid())
  branchId  String?       // v8: خزنة لكل فرع
  balance   Float         @default(0)
  totalIn   Float         @default(0)
  totalOut  Float         @default(0)
  updatedAt DateTime      @updatedAt
  entries   WalletEntry[]
  branch    Branch?       @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model WalletEntry {
  id        String         @id @default(uuid())
  type      String         // DEPOSIT | WITHDRAW | ALLOCATE_TO_PROJECT | RETURN_FROM_PROJECT
  amount    Float
  note      String?
  walletId  String
  createdBy String
  createdAt DateTime       @default(now())
  wallet    CompanyWallet  @relation(fields: [walletId], references: [id])
  creator   User           @relation("WalletEntryCreator", fields: [createdBy], references: [id])
}

// ─────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────
model Project {
  id               String            @id @default(uuid())
  name             String
  description      String?
  budget           Float?
  custody          Float?            @default(0)    // Legacy — kept for backward compat
  budgetAllocated  Float             @default(0)    // V2: مأخوذ من خزنة الشركة
  custodyIssued    Float             @default(0)    // V2: مجموع العهدات المصروفة
  custodyReturned  Float             @default(0)    // V2: مجموع الكاش المُرجَع
  managerSpent     Float             @default(0)    // V3: ما صرفه المدير مباشرة من العهدة الضمنية
  status           String            @default("PENDING") // PENDING | IN_PROGRESS | CLOSED
  image            String?           // V3: صورة أو لوجو المشروع
  startDate        DateTime?
  endDate          DateTime?
  closedAt         DateTime?
  managerId        String?
  branchId         String?           // v8: المشروع يتبع فرع
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?

  // Relations
  branch           Branch?           @relation(fields: [branchId], references: [id])
  invoices         Invoice[]
  messages         Message[]
  manager          User?             @relation("ProjectManager", fields: [managerId], references: [id])
  members          ProjectMember[]
  purchases        Purchase[]
  custodies        EmployeeCustody[]

  @@index([branchId])
}

// ─────────────────────────────────────────────
// PROJECT MEMBER
// ─────────────────────────────────────────────
model ProjectMember {
  id              String            @id @default(uuid())
  projectId       String
  userId          String
  role            String            @default("MEMBER")        // Legacy — kept for backward compat
  // V4: أدوار متعددة مخزنة كـ CSV — مثال: "PROJECT_EMPLOYEE,PROJECT_MANAGER"
  // القيم المتاحة: PROJECT_EMPLOYEE | PROJECT_MANAGER
  projectRoles    String            @default("PROJECT_EMPLOYEE")
  custodyBalance  Float             @default(0)               // رصيد عهدة الموظف الإجمالي في هذا المشروع
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  custodies       EmployeeCustody[]

  @@unique([projectId, userId])
  @@index([userId])               // P1: fast lookup of all projects a user belongs to
  @@index([projectId])            // P1: fast lookup of all members in a project
}

// ─────────────────────────────────────────────
// EMPLOYEE CUSTODY (عهدة الموظف)
// ─────────────────────────────────────────────
model EmployeeCustody {
  id            String                @id @default(uuid())
  projectId     String?               // v7: اختياري — عهدة الشركة لا تحتاج مشروع
  employeeId    String
  memberId      String?               // FK to ProjectMember
  amount        Float                 // المبلغ المصروف الأصلي
  balance       Float                 @default(0) // V3: المتبقي الحالي (يتناقص بكل فاتورة مقبولة)
  method        String                @default("CASH") // CASH | BANK
  isConfirmed   Boolean               @default(false)
  confirmedAt   DateTime?
  isClosed      Boolean               @default(false) // عند إرجاع كامل المتبقي
  closedAt      DateTime?
  note          String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // v7: Custody status tracking (replaces deletion on reject)
  status           String             @default("PENDING") // PENDING | CONFIRMED | REJECTED
  rejectedReason   String?            // سبب الرفض من الموظف
  rejectedAt       DateTime?

  // v7: Company expense custody (not tied to a project)
  isCompanyExpense Boolean            @default(false)

  // v5: External payee fields
  isExternal       Boolean            @default(false)
  externalName     String?            // اسم الشخص الخارجي
  externalPhone    String?            // رقم هاتف للتواصل
  externalPurpose  String?            // الغرض من الصرف
  externalSignature String?           // صورة توقيع مرفوعة

  project       Project?              @relation(fields: [projectId], references: [id])
  employee      User                  @relation(fields: [employeeId], references: [id])
  member        ProjectMember?        @relation(fields: [memberId], references: [id])
  invoices      Invoice[]             // الفواتير المرتبطة بهذه العهدة
  confirmation  CustodyConfirmation?
  returns       CustodyReturn[]       // سجل عمليات الإرجاع

  @@index([employeeId, isClosed])  // P1: employee's open custodies
  @@index([projectId, isClosed])   // P1: project's open custodies
  @@index([isCompanyExpense])      // v7: company custodies lookup
}

model CustodyConfirmation {
  id            String           @id @default(uuid())
  custodyId     String           @unique
  confirmedAt   DateTime         @default(now())
  signatureFile String?          // v5: مسار ملف التوقيع PNG
  voucherFile   String?          // v5: مسار سند الصرف PDF
  confirmedById String?          // v6: من أكّد الاستلام (للتدقيق)
  custody       EmployeeCustody  @relation(fields: [custodyId], references: [id])
  confirmedBy   User?            @relation("CustodyConfirmer", fields: [confirmedById], references: [id])
}

// سجل عمليات إرجاع الكاش من الموظف
model CustodyReturn {
  id            String          @id @default(uuid())
  custodyId     String
  amount        Float           // المبلغ المُرجَع
  returnedBy    String          // الموظف الذي أرجع
  recordedBy    String          // المدير/المنسق الذي سجّل
  note          String?
  signatureFile String?         // v5: توقيع المحاسب PNG
  voucherFile   String?         // v5: مسار سند القبض PDF
  createdAt     DateTime        @default(now())
  custody       EmployeeCustody @relation(fields: [custodyId], references: [id])
  returner      User            @relation("CustodyReturner", fields: [returnedBy], references: [id])
  recorder      User            @relation("CustodyRecorder", fields: [recordedBy], references: [id])
}

// ─────────────────────────────────────────────
// CATEGORY (تصنيفات المصاريف)
// ─────────────────────────────────────────────
model Category {
  id        String    @id @default(uuid())
  name      String    // "طعام" | "نقل" | "مستلزمات" | "أخرى"
  icon      String?
  scope     String    @default("PROJECT")  // v5: PROJECT | COMPANY | BOTH
  branchId  String?   // v8: تصنيف خاص بفرع (null = مشترك لكل الفروع)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  invoices  Invoice[]
  branch    Branch?   @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

// ─────────────────────────────────────────────
// INVOICE (الفاتورة)
// ─────────────────────────────────────────────
model Invoice {
  id              String            @id @default(uuid())
  reference       String            @unique
  type            String
  amount          Float
  status          String            @default("PENDING")  // PENDING | APPROVED | REJECTED
  date            DateTime          @default(now())
  notes           String?
  filePath        String?
  projectId       String?
  creatorId       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  isDeleted       Boolean           @default(false)
  deletedAt       DateTime?

  // V2 additions
  rejectionReason String?           // إجباري عند الرفض
  // V3: paymentSource يدعم 4 قيم:
  // CUSTODY = كل المبلغ من العهدة
  // PERSONAL = كل المبلغ من الجيب
  // SPLIT = جزء من العهدة + جزء من الجيب
  // COMPANY_DIRECT = v5: مصاريف شركة مباشرة (بلا custody)
  paymentSource   String            @default("CUSTODY")  // CUSTODY | PERSONAL | SPLIT | COMPANY_DIRECT
  custodyAmount   Float?            // V3: جزء من العهدة (في حالة SPLIT)
  pocketAmount    Float?            // V3: جزء من الجيب (في حالة SPLIT)
  custodyId       String?           // مرتبطة بعهدة الموظف
  categoryId      String?           // تصنيف المصروف
  approvedBy      String?           // V3: من اعتمد الفاتورة (للتتبع)
  approvedAt      DateTime?         // I10: وقت الاعتماد
  rejectedBy      String?           // V3: من رفض الفاتورة
  rejectedAt      DateTime?         // I10: وقت الرفض

  // v5 additions
  expenseScope    String            @default("PROJECT")   // PROJECT | COMPANY
  externalNumber  String?           // v5: رقم الفاتورة الحقيقي (فريد — يُفحص server-side)
  spendDate       DateTime?         // v5: تاريخ الصرف الفعلي

  // Relations
  creator         User              @relation("InvoiceCreator", fields: [creatorId], references: [id])
  project         Project?          @relation(fields: [projectId], references: [id])
  custody         EmployeeCustody?  @relation(fields: [custodyId], references: [id])
  category        Category?         @relation(fields: [categoryId], references: [id])
  items           InvoiceItem[]     // بنود التنسيق
  outOfPocketDebt OutOfPocketDebt?  // إذا كان PERSONAL أو SPLIT

  @@index([status, isDeleted])    // P1: filter by status + soft-delete flag
  @@index([creatorId, status])    // P1: user's own invoices filtered by status
  @@index([projectId, status])    // P1: project invoices filtered by status
  @@index([createdAt])            // P1: order by createdAt on large tables
  @@index([expenseScope])         // v5: filter by scope
}

// ─────────────────────────────────────────────
// INVOICE ITEM (بنود التنسيق)
// ─────────────────────────────────────────────
model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  name        String   // اسم المشترى
  itemNumber  String?  // رقم المشترى
  description String?  // وصف المشترى
  quantity    Float    @default(1)
  unitPrice   Float?   // سعر الوحدة
  totalPrice  Float    // إجمالي البند
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// OUT-OF-POCKET DEBT (ديون الموظف الشخصية)
// ─────────────────────────────────────────────
model OutOfPocketDebt {
  id          String    @id @default(uuid())
  invoiceId   String    @unique
  employeeId  String
  amount      Float
  isSettled   Boolean   @default(false)
  settledAt   DateTime?
  settledBy   String?
  createdAt   DateTime  @default(now())

  invoice     Invoice   @relation(fields: [invoiceId], references: [id])
  employee    User      @relation(fields: [employeeId], references: [id])
  settler     User?     @relation("DebtSettler", fields: [settledBy], references: [id])

  @@index([employeeId, isSettled]) // P1: employee's unsettled debts
  @@index([isSettled])             // P1: admin view of all unsettled debts
}

// ─────────────────────────────────────────────
// AUTO APPROVAL RULE (قواعد الاعتماد التلقائي)
// ─────────────────────────────────────────────
model AutoApprovalRule {
  id              String   @id @default(uuid())
  maxAmount       Float    // الحد الأقصى للاعتماد التلقائي
  requiresManager Boolean  @default(false) // يحتاج موافقة المدير إذا تجاوز الحد
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────
// SYSTEM SETTINGS (إعدادات النظام)
// ─────────────────────────────────────────────
model Setting {
  id        String   @id @default("global") // We will only have one global setting row
  currency  String   @default("QAR")       // ر.ق as default
  updatedAt DateTime @updatedAt
}


// ─────────────────────────────────────────────
// FINANCE REQUEST (طلبات المالية — المحاسب يطلب، المدير يوافق)
// ─────────────────────────────────────────────
model FinanceRequest {
  id          String    @id @default(uuid())
  // SETTLE_DEBT | ALLOCATE_BUDGET | RETURN_CUSTODY | OTHER
  type        String
  requestedBy String
  approvedBy  String?
  // PENDING | APPROVED | REJECTED
  status      String    @default("PENDING")
  amount      Float?
  targetId    String?   // ID الكيان المستهدف (debtId, projectId, custodyId)
  note        String?
  rejectReason String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  requester   User      @relation("FinanceRequester", fields: [requestedBy], references: [id])
  approver    User?     @relation("FinanceApprover", fields: [approvedBy], references: [id])
}

// ─────────────────────────────────────────────
// PURCHASE (V3: قائمة مشتريات يضيفها المنسق)
// ─────────────────────────────────────────────
model Purchase {
  id           String    @id @default(uuid())
  orderNumber  String    @unique
  description  String
  amount       Float     @default(0) // Legacy
  quantity     String    @default("1")
  deadline     DateTime?
  // V3: REQUESTED (المنسق طلب) | IN_PROGRESS (الموظف بالطريق) | PURCHASED (اشتُري) | CANCELLED
  status       String    @default("REQUESTED")
  // V4: NORMAL | HIGH | URGENT — مشتريات المدير العام تُعيَّن تلقائياً URGENT وتظهر أولاً
  priority     String    @default("NORMAL")
  date         DateTime  @default(now())
  projectId    String?
  creatorId    String    // المنسق الذي طلب الشراء
  purchasedBy  String?   // الموظف الذي اشترى
  invoiceId    String?   // الفاتورة المرتبطة بعد الشراء
  notes        String?   // ملاحظات للموظف
  imageUrl     String?   // V3: صورة مرفقة للشراء (اختياري)
  isRedFlagged Boolean   @default(false)
  redFlagReason String?  // سبب الراية الحمراء (مثلاً: المنتج غير متوفر)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  creator      User      @relation(fields: [creatorId], references: [id])
  project      Project?  @relation(fields: [projectId], references: [id])

  @@index([projectId, status, isDeleted])  // P1: project purchases by status
  @@index([status, isDeleted])             // P1: global purchases list
  @@index([priority, isDeleted])           // P1: urgent purchases lookup
}

// ─────────────────────────────────────────────
// DEPOSIT (Legacy)
// ─────────────────────────────────────────────
model Deposit {
  id          String   @id @default(uuid())
  type        String
  description String
  amount      Float
  date        DateTime @default(now())
  creatorId   String
  createdAt   DateTime @default(now())
  creator     User     @relation(fields: [creatorId], references: [id])
}

// ─────────────────────────────────────────────
// MESSAGE
// ─────────────────────────────────────────────
model Message {
  id            String   @id @default(uuid())
  content       String
  filePath      String?
  isProjectChat Boolean  @default(false)
  senderId      String
  receiverId    String?
  projectId     String?
  createdAt     DateTime @default(now())
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  receiver      User?    @relation("MessageReceiver", fields: [receiverId], references: [id])
  sender        User     @relation("MessageSender", fields: [senderId], references: [id])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────
model Notification {
  id              String   @id @default(uuid())
  title           String
  content         String
  targetRole      String?
  targetProjectId String?
  targetUserId    String?  // V2: إشعار موجه لموظف بعينه
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
  @@index([targetUserId, createdAt])  // P1: user-specific notifications sorted by date
  @@index([targetRole, createdAt])    // P1: role-based notifications
  @@index([isRead])                   // P1: unread count queries
}

// ─────────────────────────────────────────────
// VOUCHER COUNTER (عداد السندات)
// ─────────────────────────────────────────────
model VoucherCounter {
  id          String  @id @default(uuid())
  branchId    String? // v8: عداد لكل فرع
  lastIssue   Int     @default(0)   // آخر رقم سند صرف
  lastReceipt Int     @default(0)   // آخر رقم سند قبض
  branch      Branch? @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

// ─────────────────────────────────────────────
// PUSH SUBSCRIPTION (اشتراكات الإشعارات)
// ─────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   // Client public key
  auth      String   // Auth secret
  createdAt DateTime @default(now())

  @@index([userId])
}
