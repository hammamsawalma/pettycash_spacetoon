{
  "name": "project-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:prod": "npm run build && TEST_PROD=1 npx playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:unit": "playwright test --config=playwright.unit.config.ts",
    "test:phase1": "npx playwright test tests/auth.setup.ts tests/phase-1/ --workers=2",
    "test:phase2": "npx playwright test tests/auth.setup.ts tests/phase-2/ --workers=2",
    "test:phase3": "npx playwright test tests/auth.setup.ts tests/phase-3/ --workers=2",
    "test:phase4": "npx playwright test tests/auth.setup.ts tests/phase-4/ --workers=2",
    "test:phase5": "npx playwright test tests/auth.setup.ts tests/phase-5/ --workers=2",
    "test:regression": "npx playwright test tests/auth.setup.ts tests/phase-1/ tests/phase-2/ tests/phase-3/ tests/phase-4/ tests/phase-5/ --workers=2",
    "test:regression:prod": "npm run build && TEST_PROD=1 npx playwright test tests/auth.setup.ts tests/phase-1/ tests/phase-2/ tests/phase-3/ tests/phase-4/ tests/phase-5/ --workers=2",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.34.5",
    "jose": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.7.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
